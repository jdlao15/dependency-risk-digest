{
  "name": "dependency-risk-digest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate:digest": "node scripts/generate-digest.mjs",
    "generate:seo": "node scripts/generate-static-seo.mjs",
    "watchdog": "node scripts/watchdog.mjs",
    "refresh": "npm run generate:digest && npm run generate:seo && npm run build",
    "build": "tsc -b && vite build && node scripts/generate-route-html.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "4.3.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.7.2",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1"
  }
}
