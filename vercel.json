{
  "buildCommand": "npm run refresh",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/advertise",
      "destination": "/weekly",
      "permanent": true
    },
    {
      "source": "/sponsor",
      "destination": "/weekly",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
